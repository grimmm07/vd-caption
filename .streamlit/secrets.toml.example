# Example secrets for Streamlit Community Cloud.
# On the cloud: open your app -> Settings -> Secrets, and paste the lines below
# (with your real values). Do NOT commit a real secrets.toml — it is gitignored.

GEMINI_API_KEY = "your-key-here"
GEMINI_MODEL = "gemini-2.5-flash"
MAX_UPLOAD_MB = "200"
