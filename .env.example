# Copy this file to `.env` and fill in your values. NEVER commit `.env`.

# Your Google Gemini API key (from https://aistudio.google.com/apikey).
GEMINI_API_KEY=

# The Gemini model to use. This SDK does not hard-code a model — pass any
# identifier your key supports. `gemini-2.5-flash` is a stable, widely-available
# default that handles audio/video understanding and JSON output well.
# To see what your key can use, run the app and click "List models my key can
# use", or run `python -c "from google import genai; import os; \
#   [print(m.name) for m in genai.Client(api_key=os.environ['GEMINI_API_KEY']).models.list()]"`.
GEMINI_MODEL=gemini-2.5-flash

# Maximum upload size in megabytes (optional; default 500).
MAX_UPLOAD_MB=500

# Set to 1 to enable verbose/debug logging (may include transcript text).
DEBUG=0
